# ── Transaction Intelligence — Streamlit Secrets Template ───────────────────
#
# 1. Copy this file to .streamlit/secrets.toml  (it is gitignored)
# 2. Fill in your real TigerGraph values
# 3. On Streamlit Cloud: paste the contents of [tigergraph] into
#    App Settings → Secrets  (no filename needed — paste directly)
#
# Your TigerGraph API secret is found in:
#   GraphStudio → Admin Portal → Users → Secrets → Create Secret
# ─────────────────────────────────────────────────────────────────────────────

[tigergraph]
host       = "https://your-instance.tgcloud.io"
graph_name = "Tran_graph"
username   = "your@email.com"
secret     = "your_api_secret_here"
use_ssl    = true
